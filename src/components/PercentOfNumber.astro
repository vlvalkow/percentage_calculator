---
/* No framework needed */
---

<!-- Q1: What is __ % of __ ? -->
<div class="card shadow-sm">
  <div class="card-body p-4 py-5">
    <div class="d-flex flex-column row-gap-3">
      <h2>What is the result of</h2>
      <form id="percent_of_form" class="fs-5" novalidate>
        <div class="d-flex flex-column row-gap-3">
          <div class="d-flex flex-wrap row-gap-2">
            <div class="d-flex align-items-center flex-grow-1">
              <div class="input-group">
                <input
                  id="percent_of_form_x_value"
                  type="text"
                  name="percent_of_form_x_value"
                  inputmode="decimal"
                  min="0"
                  placeholder="X"
                  required
                  class="form-control form-control-lg"
                  aria-label="Percent"
                />
                <span class="input-group-text">%</span>
              </div>
              <span
                class="fs-5 text-end text-sm-center min-w-2 min-w-lg-auto mx-0 mx-md-3"
                >of</span
              >
            </div>
            <div class="d-flex align-items-center flex-grow-1">
              <input
                id="percent_of_form_y_value"
                type="text"
                name="percent_of_form_y_value"
                inputmode="decimal"
                placeholder="Y"
                required
                class="form-control form-control-lg"
                aria-label="Number"
              />
              <span class="fs-5 text-end min-w-2 min-w-lg-auto ms-0 ms-lg-3"
                >?</span
              >
            </div>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-lg"
              >Calculate</button
            >
            <button type="reset" class="btn btn-outline-secondary btn-lg"
              >Reset</button
            >
          </div>
        </div>
      </form>

      <div class="alert alert-info mb-0 fs-5" role="status" aria-live="polite">
        <span id="percentOfResult" class="fw-semibold"
          >Enter values and click Calculate.</span
        >
      </div>

      <div class="d-flex align-items-center justify-content-between">
        <p class="text-muted mb-0">
          Formula:
          <span class="font-monospace">(X / 100) × Y</span>
        </p>
        <button
          type="button"
          class="btn btn-lg btn-transparent p-0 mb-1"
          data-bs-toggle="tooltip"
          data-bs-placement="top"
          data-bs-title="Example: What is the savings amount given a discount of 15% on the original price of 500?"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            fill="currentColor"
            class="bi bi-info-circle-fill"
            viewBox="0 0 16 16"
          >
            <path
              d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.47l-.451-.081.082-.381 2.29-.287zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2"
            ></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const toDotDecimal = (v) => String(v).replace(/,/g, ".");

  const format = (n, maxFractionDigits = 10) => {
    if (!Number.isFinite(n)) return "";
    return n.toLocaleString(undefined, {
      maximumFractionDigits: maxFractionDigits,
    });
  };

  // 1) Percent of
  const percentOfForm = document.querySelector("#percent_of_form");
  const percentOfResult = document.querySelector("#percentOfResult");

  if (percentOfForm && percentOfResult) {
    percentOfForm.addEventListener("submit", (e) => {
      e.preventDefault();

      const data = new FormData(percentOfForm);
      const pct = Number(toDotDecimal(data.get("percent_of_form_x_value")));
      const num = Number(toDotDecimal(data.get("percent_of_form_y_value")));

      if (!Number.isFinite(pct) || !Number.isFinite(num)) {
        percentOfResult.textContent = "Please enter valid numbers.";
        return;
      }

      const answer = (pct / 100) * num;
      percentOfResult.textContent = `${format(pct)}% of ${format(num)} is ${format(answer)}`;
    });

    percentOfForm.addEventListener("reset", () => {
      requestAnimationFrame(() => {
        percentOfResult.textContent = "Enter values and click Calculate.";
      });
    });
  }
</script>
